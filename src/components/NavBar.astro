---
import Button from './Button.astro';
import logoWeb from '../assets/logo.svg';
---

<header class="fixed w-full top-0 z-50 bg-white shadow-md">
    <nav>
        <input id="nav-toggle" type="checkbox" class="peer sr-only" />

        <div class="container max-w-6xl mx-auto flex items-center justify-between gap-12 px-4 py-4">
            <a href="/" class="flex items-center">
                <img src={logoWeb.src} alt="H&C Productions logo" class="h-14 w-auto" />
            </a>

            <div class="flex items-center gap-4 md:hidden">
                <label for="nav-toggle" class="inline-flex h-10 w-10 flex-col items-center justify-center space-y-1.5 cursor-pointer text-zinc-100 transition  focus-visible:outline-none focus-visible:ring-2">
                    <span class="sr-only">Abrir menú</span>
                    <span class="block h-0.5 w-6 bg-blue-800 transition-transform duration-200 peer-checked:translate-y-1.5 peer-checked:rotate-45"></span>
                    <span class="block h-0.5 w-6 bg-blue-800 transition-opacity duration-200 peer-checked:opacity-0"></span>
                    <span class="block h-0.5 w-6 bg-blue-800 transition-transform duration-200 peer-checked:-translate-y-1.5 peer-checked:-rotate-45"></span>
                </label>
            </div>

            <ul class="hidden items-center md:flex gap-6">
                <li><a href="/menu" class=" hover:text-blue-700 text-blue-800">Home</a></li>
                <li><a href="/about" class="hover:text-blue-700 text-blue-800">About</a></li>
                <li><a href="/contact" class="hover:text-blue-700 text-blue-800">Manufacturers</a></li>
                <li><a href="/contact" class="hover:text-blue-700 text-blue-800">Contact</a></li>
                <Button label="Sign Up" href="/contact" />
            </ul>
        </div>

        <div class="absolute inset-x-0 top-full z-40 block overflow-hidden max-h-0 opacity-0 scale-y-95 bg-white px-4 py-0 transition-[max-height,opacity,transform] duration-300 ease-out md:hidden peer-checked:max-h-[20rem] peer-checked:opacity-100 peer-checked:scale-y-100 peer-checked:py-4">
            <ul class="flex flex-col gap-3">
                <li><a href="/menu" class="block rounded-lg px-3 py-2 text-blue-800 hover:bg-zinc-200 hover:text-blue-700">Home</a></li>
                    <li><a href="/about" class="block rounded-lg px-3 py-2 text-blue-800 hover:bg-zinc-200 hover:text-blue-700">About</a></li>
                    <li><a href="/contact" class="block rounded-lg px-3 py-2 text-blue-800 hover:bg-zinc-200 hover:text-blue-700">Manufacturers</a></li>
                <li><a href="/contact" class="block rounded-lg px-3 py-2 text-blue-800 hover:bg-zinc-200 hover:text-blue-700">Contact</a></li>
                <li><Button label="Sign Up" href="/contact" /> </li>
            </ul>
        </div>
    </nav>
    <div class="fixed bg-blue-800 flex justify-center w-full">
        <div class="flex flex-row justify-center gap-4 font-medium text-sm underline w-11/12">
            <a href="/contact" class="block text-center text-white py-2 ">Office: (123) 456-7890</a>
            <a href="/contact" class="block text-center text-white py-2 ">Request a Quote</a>
        </div>
    </div>
</header>