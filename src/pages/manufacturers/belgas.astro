---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";
import CardAbout from "../../components/CardAbout.astro"
import Products from "../../layouts/Products.astro";
import belgas from "../../assets/belgas.webp"
import image1 from "../../assets/pressure-reducing-regulators.webp";
import image2 from "../../assets/back-pressure.webp";
import image3 from "../../assets/slam-shuts.webp";
import image4 from "../../assets/electronic-pressure-control.webp";
import image5 from "../../assets/filters-regulators.webp";
import image6 from "../../assets/accesories.webp";

const products = [
  {
    title: 'Pressure Reducing Regulators',
    description: 'Reliable pressure reducing regulators engineered to maintain stable downstream pressure for gas and liquid systems.',
    backgroundImage: image1,
  },
  {
    title: 'Back Pressure / Pressure Relieving Regulators',
    description: 'Back pressure and pressure relieving regulators designed to protect systems by keeping upstream pressure within safe limits.',
    backgroundImage: image2,
  },
  {
    title: 'Slam Shuts /  Over Pressure Shut Off',
    description: 'Fast-acting slam shut valves that immediately close to prevent overpressure and protect critical equipment.',
    backgroundImage: image3,
  },
  {
    title: 'Electronic Pressure Control Regulators',
    description: 'Electronic pressure control regulators offering precise digital control and improved system accuracy.',
    backgroundImage: image4,
  },
  {
    title: 'Filters, Regulators, Lubricators',
    description: 'Integrated filter-regulator-lubricator units that improve air quality, regulate pressure, and ensure smooth operation.',
    backgroundImage: image5,
  },
  {
    title: 'Accesories',
    description: 'Essential accessories to support installation and maintenance of regulators and control equipment.',
    backgroundImage: image6,
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "#",
  name: "H&C Productions",
  url: "#",
  logo: "#",
  description: "#",  sameAs: [
    "#",
    "#"
  ]
};
---
<Layout title="H&C Products" description="H&C Products, California 5650 District Blvd Suite 101 Bakersfield, Ca. 93313; Phone Office: (661) 397-0290;" canonical="/manufacturers/belgas">
  <div class="container w-11/12 max-w-6xl mx-auto pt-40">
    <CardAbout title='Electric Actuators and Controls' subtitle='AMERICAN MANUFACTURER OF' description='Indelac Controls, Inc. manufactures a broad range of products for the valve and damper automation industry.' image={{ src: belgas.src, alt: 'image'}} imagePosition='top' button={{href: '', label:"See catalog"}}/>
  </div>
  <Products products={products} />
</Layout>