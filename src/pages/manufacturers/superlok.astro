    backgroundImage: image5,
  },
  {
    title: 'Relief Valves',
    description: 'Relief valves that protect systems by safely releasing excess pressure under critical conditions.',
    backgroundImage: image6,
  },
  {
    title: 'Superlok Check Valves',
    description: 'Check valves that prevent reverse flow and help maintain system integrity and efficiency.',
    backgroundImage: image7,
  },
  {
    title: 'Superlok Plug Valves',
    description: 'Plug valves designed for reliable shutoff and straightforward operation in process piping.',
    backgroundImage: image8,
  },
  {
    title: 'Superlok Flared Fittings',
    description: 'Flared fittings that provide secure, leak-resistant connections for high-pressure tubing applications.',
