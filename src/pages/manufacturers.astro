---
import Layout from '../layouts/Layout.astro';

import imageOne from '../assets/indelac.webp';
import imageTwo from '../assets/belgas.webp';
import imageThree from '../assets/reotemp.webp';
import imageFour from '../assets/superlok.webp';
import imageFive from '../assets/delta-controls.webp'

const brands = [
  {
    name: 'Indelac',
    href: '/H-CProductions/manufacturers/indelac',
    description: 'High-performance solutions designed for modern production environments.',
    image: { src: imageOne.src, alt: 'Indelac brand image' }
  },
  {
    name: 'Belgas',
    href: '/H-CProductions/manufacturers/belgas',
    description: 'Reliable equipment and support for demanding industrial applications.',
    image: { src: imageTwo.src, alt: 'Belgas brand image' }
  },
  {
    name: 'Reotemp',
    href: '/H-CProductions/manufacturers/reotemp',
    description: 'Versatile systems built to streamline daily operations.',
    image: { src: imageThree.src, alt: 'Reotemp brand image' }
  },
  {
    name: 'Superlok',
    href: '/H-CProductions/manufacturers/superlok',
    description: 'Premium components crafted for efficiency and long-lasting performance.',
    image: { src: imageFour.src, alt: 'Superlok brand image' }
  },
  {
    name: 'Delta controls',
    href: '/H-CProductions/manufacturers/delta-controls',
    description: 'Premium components crafted for efficiency and long-lasting performance.',
    image: { src: imageFive.src, alt: 'Delta controls brand image' }
  }
];
---

<Layout title="Manufacturers" description="Explore our featured manufacturer brands." canonical='/manufacturers/{{'>
  <main class="pb-20 pt-64">
    <section class="mx-auto max-w-6xl px-4">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-blue-700">Manufacturers</p>
        <h1 class="mt-3 text-4xl font-semibold text-zinc-900 sm:text-5xl">Discover our featured brands</h1>
        <p class="mt-4 text-lg text-zinc-600">Choose a manufacturer to explore a dedicated page with more details.</p>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {brands.map((brand) => (
          <a
            href={brand.href}
            class=" border border-zinc-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-blue-600 hover:shadow-md h-fit"
          >
            {brand.image && (
              <img
                src={brand.image.src}
                alt={brand.image.alt}
                class="mb-5  h-auto w-full object-fit"
              />
            )}
            <h2 class="text-xl font-semibold text-zinc-900">{brand.name}</h2>
            <p class="mt-2 text-sm leading-6 text-zinc-600">{brand.description}</p>
            <span class="mt-4 inline-flex text-sm font-semibold text-blue-700">View page →</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>
